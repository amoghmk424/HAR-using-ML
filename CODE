# ---------------- IMPORTS ----------------
import numpy as np
import pandas as pd
import pickle
from collections import Counter
from tensorflow.keras.models import load_model
from google.colab import files

# ---------------- CONFIG ----------------
FEATURE_COLUMNS = [
    'X_Acceleration', 'Y_Acceleration', 'Z_Acceleration',
    'X_AngularVelocity', 'Y_AngularVelocity', 'Z_AngularVelocity',
    'X_MagneticField', 'Y_MagneticField', 'Z_MagneticField'
]

# ---------------- LOAD TRAINED FILES ----------------
model = load_model("har_fullzip_model.h5")   # model trained WITHOUT windows
scaler = pickle.load(open("scaler.pkl", "rb"))
le = pickle.load(open("label_encoder.pkl", "rb"))

print("✅ Model, scaler, and label encoder loaded")

# ---------------- UPLOAD CSV FILE ----------------
print("\n📂 Upload CSV file containing sensor data")
uploaded = files.upload()

csv_file = list(uploaded.keys())[0]
df = pd.read_csv(csv_file)

print("CSV file loaded:", csv_file)
print("Total rows:", len(df))

# ---------------- CHECK REQUIRED COLUMNS ----------------
missing_cols = [c for c in FEATURE_COLUMNS if c not in df.columns]
if missing_cols:
    raise ValueError(f"❌ Missing columns in CSV file: {missing_cols}")

# ---------------- PREPROCESS DATA ----------------
X = df[FEATURE_COLUMNS].values
X_scaled = scaler.transform(X)

# ---------------- PREDICT PER SAMPLE ----------------
pred_probs = model.predict(X_scaled, verbose=0)
pred_labels = np.argmax(pred_probs, axis=1)
pred_activities = le.inverse_transform(pred_labels)

# ---------------- DISPLAY SAMPLE OUTPUT ----------------
print("\n📊 SAMPLE-WISE PREDICTIONS (first 20 rows):\n")
for i, act in enumerate(pred_activities[:20]):
    print(f"Sample {i+1}: {act}")

if len(pred_activities) > 20:
    print("...")

# ---------------- FINAL COMMON ACTIVITY ----------------
activity_counts = Counter(pred_activities)
final_activity = activity_counts.most_common(1)[0][0]

print("\n✅ FINAL DETECTED ACTIVITY (WHOLE DATASET):")
print("➡️", final_activity)

# ---------------- OPTIONAL: ACTIVITY DISTRIBUTION ----------------
print("\n📈 Activity Distribution:")
for act, count in activity_counts.items():
    print(f"{act:12s} : {count}")
